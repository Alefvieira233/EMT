# =====================================================
# .gitattributes — FerramentaEMT
# Normalizacao de fim-de-linha para evitar diffs ruidosos
# entre editores Windows (CRLF) e o repositorio (LF).
# =====================================================

# Padrao: autodetecta arquivos de texto e normaliza para LF no repo.
* text=auto eol=lf

# Arquivos especificamente do ecossistema .NET / Visual Studio
# geralmente usam CRLF — manter para evitar estranheza na IDE.
*.sln      text eol=crlf
*.csproj   text eol=crlf
*.vbproj   text eol=crlf
*.props    text eol=crlf
*.targets  text eol=crlf

# Scripts Windows
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Scripts Unix
*.sh       text eol=lf

# Binarios — nunca normalizar
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.dll      binary
*.pdb      binary
*.exe      binary
*.xlsx     binary
*.docx     binary
*.pptx     binary
