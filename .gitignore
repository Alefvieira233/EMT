# =====================================================
# .gitignore — FerramentaEMT (Revit add-in)
# =====================================================

# --- .NET build outputs ---
bin/
obj/
out/
artifacts/
publish/
*.dll
*.pdb
*.exe
*.cache
*.suo
*.user

# --- Visual Studio ---
.vs/
*.vssscc
*.vspscc
*.vsdx
.vshistory/

# --- VS Code / Rider ---
.vscode/
.idea/
*.code-workspace

# --- NuGet ---
packages/
*.nupkg
*.snupkg
.nuget/
project.lock.json
project.fragment.lock.json

# --- Testes ---
TestResults/
coverage/
*.coverage
*.coveragexml
*.opencover.xml
lcov.info

# --- ReSharper ---
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# --- Logs ---
*.log
logs/

# --- Outputs locais ---
*.local
*.tmp
*.bak
*.old

# --- Específicos do Revit / FerramentaEMT ---
# Templates não-default que sejam de teste:
Templates/_test_*.xlsx
Templates/_temp_*.xlsx
# Pasta de instalador gerada:
installer/output/
*.msi
*.exe.config

# --- Sistema operacional ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# --- Backup do Claude / IA ---
.claude/cache/
.claude/sessions/

# --- Secrets ---
*.env
*.env.local
secrets.json
appsettings.Local.json
.github-token
# Segredo HMAC de licenciamento — NUNCA commitar. Deve ficar em
# %LOCALAPPDATA%\FerramentaEMT\ ou via variavel EMT_LICENSE_SECRET.
license.secret
*.license.secret
# DSN do Sentry — carregado em runtime, nao deve ficar no repo.
# Match em qualquer profundidade. *.sentry.dsn cobre backups/variantes
# (ex.: dev.sentry.dsn, prod.sentry.dsn) por paranoia, mesmo padrao do
# license.secret. Ver ADR-007 §Operational Runbook.
sentry.dsn
*.sentry.dsn
# API key do PostHog — mesmo padrao do sentry.dsn. Carregada em runtime
# via env var EMT_POSTHOG_API_KEY ou arquivo em %LocalAppData%. Ver
# ADR-008 §Operational Runbook.
posthog.apikey
*.posthog.apikey
# Session ID anonimo da telemetria — UUID v4 persistido por instalacao.
# Local-only, nao deve ser versionado.
session-id.json

# v1.7.0 PR-5 (P0.1): certificados de code signing — NUNCA commitar.
# .pfx eh gerado com chave privada exportavel; commit eh comprometimento
# total da identidade de assinatura. Mesmo padrao do license.secret +
# sentry.dsn + posthog.apikey: env var (EMT_CODESIGN_CERT_PFX) ou path
# fora do repo. Ver docs/CODE-SIGNING.md + docs/ADR/009-code-signing.md.
*.pfx
*.p12
*.cer.password

# --- Relatorios de comparacao (apoio local) ---
comparacao-victor/

# --- Pacotes de upload / backups locais ---
up emt/
up emt.zip
FerramentaEMT_Completo.zip
FerramentaEMT_Patch_DropIn.zip
*.zip

# Wave 2 (Incorporacao Victor 2026-04-25) — backups locais nao versionados
*.bak-alef-v1.5
