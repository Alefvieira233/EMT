<Window x:Class="FerramentaEMT.Views.PfBeamStirrupsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PM - Estribos Viga"
        Width="640"
        MinHeight="380"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Estribos em Viga" Style="{StaticResource DialogTitleText}"/>
            <TextBlock Text="Distribui os estribos ao longo do comprimento detectado da viga."
                       Style="{StaticResource DialogSubtitleText}"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <GroupBox Header="Configuracao">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Comprimento viga (cm):" VerticalAlignment="Center" Margin="0 0 8 8"/>
                    <TextBox x:Name="txtComprimentoViga" Grid.Row="0" Grid.Column="1" Margin="0 0 0 8" IsReadOnly="True"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Diametro barra (mm):" VerticalAlignment="Center" Margin="0 0 8 8"/>
                    <TextBox x:Name="txtDiametro" Grid.Row="1" Grid.Column="1" Margin="0 0 0 8" Text="6.3"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Cobrimento (cm):" VerticalAlignment="Center" Margin="0 0 8 8"/>
                    <TextBox x:Name="txtCover" Grid.Row="2" Grid.Column="1" Margin="0 0 0 8" Text="3"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Espacamento (cm):" VerticalAlignment="Center" Margin="0 0 8 8"/>
                    <TextBox x:Name="txtEspacamento" Grid.Row="3" Grid.Column="1" Margin="0 0 0 8" Text="12"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Formato Revit:" VerticalAlignment="Center" Margin="0 0 8 8"/>
                    <ComboBox x:Name="cmbShape" Grid.Row="4" Grid.Column="1" Margin="0 0 0 8"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Dobra:" VerticalAlignment="Center" Margin="0 0 8 0"/>
                    <ComboBox x:Name="cmbDobra" Grid.Row="5" Grid.Column="1" SelectedIndex="0">
                        <ComboBoxItem Content="135 graus"/>
                        <ComboBoxItem Content="90 graus"/>
                    </ComboBox>

                    <Border Grid.Row="0" Grid.Column="3" Grid.RowSpan="6"
                            Padding="8"
                            BorderBrush="#22000000"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="#08FFFFFF">
                        <StackPanel>
                            <TextBlock Text="Previa do formato" FontWeight="SemiBold" Margin="0 0 0 8"/>
                            <Border Height="180" BorderBrush="#22000000" BorderThickness="1" CornerRadius="4" Background="White" Padding="12">
                                <Grid>
                                    <Image x:Name="imgShapePreview" Stretch="Uniform" Margin="4"/>
                                    <StackPanel x:Name="panelShapePreviewFallback" VerticalAlignment="Center">
                                        <TextBlock x:Name="txtShapePreviewTag"
                                                   Text="Automatico"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0 18 0 10"/>
                                        <TextBlock x:Name="txtShapePreviewCaption"
                                                   Text="O formato selecionado aparece aqui para conferencia rapida."
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   Foreground="#88000000"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="txtShapePreviewTitle" Margin="0 8 0 0" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtShapePreviewHint" TextWrapping="Wrap" Margin="0 4 0 0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </GroupBox>

            <Border Margin="0 12 0 0" Padding="12" CornerRadius="8" Background="#11000000">
                <StackPanel>
                    <TextBlock x:Name="txtAmostra" TextWrapping="Wrap" Margin="0 0 0 6"/>
                    <TextBlock TextWrapping="Wrap"
                               Text="Em Automatico, o add-in monta o estribo pelo cobrimento e pela dobra. Se escolher um formato do Revit, ele tenta usar exatamente o formato selecionado."/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource ActionBarBorder}" Margin="-16,12,-16,-16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancelar" Width="96" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0"/>
                <Button x:Name="btnOk" Content="Aplicar" Width="110" Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
