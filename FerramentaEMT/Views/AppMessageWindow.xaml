<Window x:Class="FerramentaEMT.Views.AppMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mensagem"
        Width="620"
        Height="420"
        MaxHeight="560"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border x:Name="toneCard" Grid.Row="0" Style="{StaticResource AccentCardBorder}" Margin="0 0 0 12">
            <StackPanel>
                <TextBlock x:Name="txtTone"
                           Text="Informacao"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentCardTextBrush}"/>
                <TextBlock x:Name="txtHeadline"
                           Text="Mensagem"
                           Style="{StaticResource DialogTitleText}"
                           FontSize="22"
                           Margin="0 6 0 0"/>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="1" Header="Detalhes">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="txtMessage"
                           Style="{StaticResource SectionBodyText}"
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </GroupBox>

        <Border Grid.Row="2" Style="{StaticResource ActionBarBorder}" Margin="-16,12,-16,-16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnSecondary"
                        Content="Cancelar"
                        Width="112"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Style="{StaticResource SecondaryActionButton}"/>
                <Button x:Name="btnPrimary"
                        Content="OK"
                        Width="112"
                        Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
