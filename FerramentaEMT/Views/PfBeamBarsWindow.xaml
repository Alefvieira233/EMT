<Window x:Class="FerramentaEMT.Views.PfBeamBarsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PM - Acos Viga"
        Width="540"
        MinWidth="460" MinHeight="400"
        MaxHeight="900"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Acos em Viga" Style="{StaticResource DialogTitleText}"/>
            <TextBlock Text="Configura barras superiores, inferiores e laterais dentro do cobrimento, com opcao de ponta reta ou dobra interna."
                       Style="{StaticResource DialogSubtitleText}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Configuracao">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Vergalhao sup.:" VerticalAlignment="Center" Margin="0 0 8 8"/>
                        <ComboBox x:Name="cmbBarSup" Grid.Row="0" Grid.Column="1" Margin="0 0 8 8"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Qtd sup.:" VerticalAlignment="Center" Margin="8 0 8 8"/>
                        <TextBox x:Name="txtQtdSup" Grid.Row="0" Grid.Column="3" Margin="0 0 0 8" Text="2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Vergalhao inf.:" VerticalAlignment="Center" Margin="0 0 8 8"/>
                        <ComboBox x:Name="cmbBarInf" Grid.Row="1" Grid.Column="1" Margin="0 0 8 8"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Qtd inf.:" VerticalAlignment="Center" Margin="8 0 8 8"/>
                        <TextBox x:Name="txtQtdInf" Grid.Row="1" Grid.Column="3" Margin="0 0 0 8" Text="2"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Vergalhao lateral:" VerticalAlignment="Center" Margin="0 0 8 8"/>
                        <ComboBox x:Name="cmbBarLat" Grid.Row="2" Grid.Column="1" Margin="0 0 8 8"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Niveis laterais:" VerticalAlignment="Center" Margin="8 0 8 8"/>
                        <TextBox x:Name="txtQtdLat" Grid.Row="2" Grid.Column="3" Margin="0 0 0 8" Text="0"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Cobrimento (cm):" VerticalAlignment="Center" Margin="0 0 8 8"/>
                        <TextBox x:Name="txtCover" Grid.Row="3" Grid.Column="1" Width="120" Text="3"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Dobra ponta:" VerticalAlignment="Center" Margin="8 0 8 8"/>
                        <ComboBox x:Name="cmbModoPonta" Grid.Row="3" Grid.Column="3" Margin="0 0 0 8"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Comp. dobra (cm):" VerticalAlignment="Center" Margin="0 0 8 0"/>
                        <TextBox x:Name="txtGancho" Grid.Row="4" Grid.Column="1" Width="120" Text="10"/>
                    </Grid>
                </GroupBox>

                <Border Margin="0 12 0 0" Padding="12" CornerRadius="8" Background="#11000000">
                    <StackPanel>
                        <TextBlock x:Name="txtAmostra" TextWrapping="Wrap" Margin="0 0 0 6"/>
                        <TextBlock TextWrapping="Wrap"
                                   Text="Quando a opcao for Dobra interna, as pontas das barras principais sao viradas para dentro da viga. Em Reta, a barra sai sem dobra."/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource ActionBarBorder}" Margin="-16,12,-16,-16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancelar" Width="96" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0"/>
                <Button x:Name="btnOk" Content="Aplicar" Width="110" Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
