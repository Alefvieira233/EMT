<Window x:Class="FerramentaEMT.Views.PfConsoloRebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PF - Acos Consolo"
        Width="560"
        MinWidth="480" MinHeight="420"
        MaxHeight="620"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Acos em Consolo" Style="{StaticResource DialogTitleText}"/>
            <TextBlock Text="Configura tirantes, suspensoes e estribos basicos para os consolos PF selecionados."
                       Style="{StaticResource DialogSubtitleText}"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <GroupBox Header="Configuracao">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tirante:" VerticalAlignment="Center" Margin="0 0 8 8"/>
                    <ComboBox x:Name="cmbTirante" Grid.Row="0" Grid.Column="1" Margin="0 0 8 8"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Qtd/Comp.:" VerticalAlignment="Center" Margin="8 0 8 8"/>
                    <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal">
                        <TextBox x:Name="txtQtdTirante" Width="56" Text="4"/>
                        <TextBox x:Name="txtCompTirante" Width="72" Margin="8,0,0,0" Text="100"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Suspensao:" VerticalAlignment="Center" Margin="0 0 8 8"/>
                    <ComboBox x:Name="cmbSuspensao" Grid.Row="1" Grid.Column="1" Margin="0 0 8 8"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Qtd/Comp.:" VerticalAlignment="Center" Margin="8 0 8 8"/>
                    <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal">
                        <TextBox x:Name="txtQtdSuspensao" Width="56" Text="4"/>
                        <TextBox x:Name="txtCompSuspensao" Width="72" Margin="8,0,0,0" Text="60"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Estribo vertical:" VerticalAlignment="Center" Margin="0 0 8 8"/>
                    <ComboBox x:Name="cmbEstriboVertical" Grid.Row="2" Grid.Column="1" Margin="0 0 8 8"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Qtd:" VerticalAlignment="Center" Margin="8 0 8 8"/>
                    <TextBox x:Name="txtQtdEstriboVertical" Grid.Row="2" Grid.Column="3" Width="72" Text="5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Estribo horizontal:" VerticalAlignment="Center" Margin="0 0 8 0"/>
                    <ComboBox x:Name="cmbEstriboHorizontal" Grid.Row="3" Grid.Column="1" Margin="0 0 8 0"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Qtd:" VerticalAlignment="Center" Margin="8 0 8 0"/>
                    <TextBox x:Name="txtQtdEstriboHorizontal" Grid.Row="3" Grid.Column="3" Width="72" Text="5"/>
                </Grid>
            </GroupBox>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource ActionBarBorder}" Margin="-16,12,-16,-16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancelar" Width="96" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0"/>
                <Button x:Name="btnOk" Content="Aplicar" Width="110" Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
