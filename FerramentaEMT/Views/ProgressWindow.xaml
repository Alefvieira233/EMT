<Window x:Class="FerramentaEMT.Views.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Processando..."
        Width="520"
        Height="220"
        MinWidth="480"
        MinHeight="200"
        MaxHeight="240"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtHeadline"
                   Grid.Row="0"
                   Text="Processando..."
                   Style="{StaticResource DialogTitleText}"
                   FontSize="18"
                   Margin="0,0,0,4"/>

        <TextBlock x:Name="txtDetail"
                   Grid.Row="1"
                   Text=""
                   Style="{StaticResource DialogSubtitleText}"
                   FontSize="12"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,12"/>

        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="progressBar"
                         Grid.Column="0"
                         Height="10"
                         Minimum="0"
                         Maximum="100"
                         Value="0"/>
            <TextBlock x:Name="txtPercent"
                       Grid.Column="1"
                       Text="0%"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="11"
                       MinWidth="40"
                       TextAlignment="Right"/>
        </Grid>

        <TextBlock x:Name="txtCounter"
                   Grid.Row="3"
                   Text=""
                   Style="{StaticResource DialogSubtitleText}"
                   FontSize="11"
                   Margin="0,4,0,0"/>

        <Border Grid.Row="4" Style="{StaticResource ActionBarBorder}" Margin="-16,12,-16,-16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel"
                        Content="Cancelar"
                        Width="112"
                        Style="{StaticResource SecondaryActionButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
