<Window x:Class="FerramentaEMT.Views.PlanoMontagemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plano de Montagem"
        Width="700"
        Height="600"
        MinWidth="620" MinHeight="520" MaxHeight="720"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titulo -->
        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Plano de Montagem (Erection Plan)" Style="{StaticResource DialogTitleText}"/>
            <TextBlock Text="Atribua etapas de montagem aos elementos, visualize o plano sequenciado, aplique destaque visual e exporte para Excel."
                       Style="{StaticResource DialogSubtitleText}"/>
        </StackPanel>

        <!-- TabControl -->
        <TabControl Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}">
            <!-- Tab 1: Atribuir Etapa -->
            <TabItem Header="Atribuir Etapa">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Número da etapa (inteiro positivo)" Style="{StaticResource LabelText}" Margin="0 0 0 4"/>
                    <TextBox x:Name="txtNumeroEtapa" Grid.Row="1" Height="32" Padding="8"
                             Background="{DynamicResource TextBoxBackgroundBrush}"
                             Foreground="{DynamicResource TextBoxForegroundBrush}"
                             Text="1" Margin="0 0 0 12"/>

                    <TextBlock Grid.Row="2" Text="Descrição (opcional)" Style="{StaticResource LabelText}" Margin="0 0 0 4"/>
                    <TextBox x:Name="txtDescricao" Grid.Row="3" Height="32" Padding="8"
                             Background="{DynamicResource TextBoxBackgroundBrush}"
                             Foreground="{DynamicResource TextBoxForegroundBrush}"
                             Margin="0 0 0 12"/>

                    <Button x:Name="btnAtribuir" Grid.Row="4" Content="Atribuir aos Selecionados" Height="36"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource ButtonForegroundBrush}"
                            VerticalAlignment="Top"
                            Click="BtnAtribuir_Click"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: Visualizar Plano -->
            <TabItem Header="Visualizar Plano">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button x:Name="btnGerarPlano" Grid.Row="0" Content="Gerar Plano de Montagem" Height="36"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource ButtonForegroundBrush}"
                            Margin="0 0 0 12"
                            Click="BtnGerarPlano_Click"/>

                    <DataGrid x:Name="dgEtapas" Grid.Row="1"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Background="{DynamicResource PanelBackgroundBrush}"
                              Foreground="{DynamicResource TextBoxForegroundBrush}"/>
                </Grid>
            </TabItem>

            <!-- Tab 3: Exportar Relatório -->
            <TabItem Header="Exportar Relatório">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Caminho do arquivo Excel" Style="{StaticResource LabelText}" Margin="0 0 0 4"/>

                    <Grid Grid.Row="1" Margin="0 0 0 12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtCaminhoRelatorio" Grid.Column="0" Height="32" Padding="8"
                                 Background="{DynamicResource TextBoxBackgroundBrush}"
                                 Foreground="{DynamicResource TextBoxForegroundBrush}"/>

                        <Button x:Name="btnBrowse" Grid.Column="1" Content="..." Width="40" Height="32"
                                Background="{DynamicResource ButtonBackgroundBrush}"
                                Foreground="{DynamicResource ButtonForegroundBrush}"
                                Margin="8 0 0 0"
                                Click="BtnBrowse_Click"/>
                    </Grid>

                    <Button x:Name="btnExportar" Grid.Row="2" Content="Exportar para Excel" Height="36"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource ButtonForegroundBrush}"
                            Click="BtnExportar_Click"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Botões OK/Cancel -->
        <Grid Grid.Row="2" Margin="0 12 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnOk" Grid.Column="1" Content="OK" Width="80" Height="32"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource ButtonForegroundBrush}"
                    Margin="0 0 8 0"
                    Click="BtnOk_Click"/>

            <Button x:Name="btnCancel" Grid.Column="2" Content="Cancelar" Width="80" Height="32"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource ButtonForegroundBrush}"
                    Click="BtnCancel_Click"/>
        </Grid>
    </Grid>
</Window>
