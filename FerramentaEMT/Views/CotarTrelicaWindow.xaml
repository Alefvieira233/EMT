<Window x:Class="FerramentaEMT.Views.CotarTrelicaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cotar Treliça"
        Width="560"
        MinWidth="480" MinHeight="420"
        MaxHeight="620"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Cotar Treliça" Style="{StaticResource DialogTitleText}"/>
            <TextBlock Text="Aplica o padrão EMT de 5 faixas de cotas e identifica os perfis na elevação/corte atual."
                       Style="{StaticResource DialogSubtitleText}"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <GroupBox Header="Faixas de cota (padrão EMT)">
                <StackPanel Margin="4">
                    <CheckBox x:Name="chkPaineisSuperior" Content="Painéis do banzo superior" IsChecked="True" Margin="0 2"/>
                    <CheckBox x:Name="chkVaosApoio"      Content="Vãos entre apoios (faixa superior)" IsChecked="True" Margin="0 2"/>
                    <CheckBox x:Name="chkPaineisInferior" Content="Painéis do banzo inferior" IsChecked="True" Margin="0 2"/>
                    <CheckBox x:Name="chkVaoTotal"       Content="Vão total da treliça (faixa inferior)" IsChecked="True" Margin="0 2"/>
                    <CheckBox x:Name="chkAlturaMontantes" Content="Altura de cada montante (texto vertical)" IsChecked="True" Margin="0 2"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Identificação de perfis" Margin="0 12 0 0">
                <StackPanel Margin="4">
                    <CheckBox x:Name="chkIdentificarPerfis" Content="Identificar perfil de cada barra (tags)" IsChecked="True" Margin="0 2"/>
                    <CheckBox x:Name="chkCantoneiraDupla"   Content="Cantoneiras (L) como peça dupla — prefixo 2x" IsChecked="True" Margin="0 2"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource ActionBarBorder}" Margin="-16,12,-16,-16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancelar" Width="96" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0"/>
                <Button x:Name="btnOk"     Content="OK"       Width="110" Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
