<Window x:Class="FerramentaEMT.Views.TercasPlanoOrigemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plano das Terças"
        Width="560"
        MinWidth="480" MinHeight="360"
        MaxHeight="520"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Escolha o Plano das Terças" Style="{StaticResource DialogTitleText}"/>
            <TextBlock Text="Defina se o plano base será obtido pelo plano de trabalho atual da vista ou por uma face plana do modelo." Style="{StaticResource DialogSubtitleText}"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="Origem do plano">
            <StackPanel>
                <Border Style="{StaticResource AccentCardBorder}" Margin="0 0 0 12">
                    <StackPanel>
                        <RadioButton x:Name="rbPlanoTrabalhoAtual"
                                     Content="Usar plano de trabalho atual"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     IsChecked="True"
                                     Margin="0 0 0 6"/>
                        <TextBlock Text="Usa o plano de trabalho já definido na vista ativa do Revit. Em seguida, você clica em um ponto para posicionar o plano onde o lançamento deve acontecer."
                                   Style="{StaticResource SectionBodyText}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SubtleCardBorder}">
                    <StackPanel>
                        <RadioButton x:Name="rbFacePlana"
                                     Content="Usar face plana do modelo"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     Margin="0 0 0 6"/>
                        <TextBlock Text="Clique em uma face plana de um elemento do modelo para usar sua orientação como plano de trabalho."
                                   Style="{StaticResource SectionBodyText}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </GroupBox>

        <Border Grid.Row="2" Style="{StaticResource ActionBarBorder}" Margin="-16,12,-16,-16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancelar" Width="96" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0"/>
                <Button x:Name="btnOk" Content="Continuar" Width="110" Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
