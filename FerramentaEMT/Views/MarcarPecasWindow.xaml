<Window x:Class="FerramentaEMT.Views.MarcarPecasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marcação Inteligente de Peças"
        Width="640"
        MinWidth="560" MinHeight="680"
        MaxHeight="820"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titulo -->
        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Marcação Inteligente de Peças" Style="{StaticResource DialogTitleText}"/>
            <TextBlock Text="Analisa elementos estruturais, agrupa peças idênticas por assinatura de fabricação (tipo + perfil + material + comprimento) e atribui marcas únicas por grupo."
                       Style="{StaticResource DialogSubtitleText}"/>
        </StackPanel>

        <!-- Escopo -->
        <GroupBox Grid.Row="1" Header="Escopo da marcação">
            <StackPanel>
                <RadioButton x:Name="rbModeloInteiro" Content="Modelo inteiro"
                             Checked="Configuracao_Changed"/>
                <RadioButton x:Name="rbVistaAtiva" Content="Vista ativa" IsChecked="True"
                             Margin="0,4,0,0" Checked="Configuracao_Changed"/>
                <RadioButton x:Name="rbSelecaoManual" Content="Seleção manual (selecionar após confirmar)"
                             Margin="0,4,0,0" Checked="Configuracao_Changed"/>
            </StackPanel>
        </GroupBox>

        <!-- Categorias e prefixos -->
        <GroupBox Grid.Row="2" Header="Categorias e prefixos">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Categoria" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Prefixo" FontWeight="SemiBold" Margin="0,0,0,4"/>

                <CheckBox x:Name="chkVigas" Grid.Row="1" Grid.Column="0"
                          Content="Vigas estruturais" IsChecked="True"
                          Checked="Configuracao_Changed" Unchecked="Configuracao_Changed"/>
                <Label Grid.Row="1" Grid.Column="1" Content="→" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPrefixoVigas" Grid.Row="1" Grid.Column="2"
                         Text="V" VerticalContentAlignment="Center" Margin="4,2"
                         TextChanged="TxtPrefixo_TextChanged"/>

                <CheckBox x:Name="chkPilares" Grid.Row="2" Grid.Column="0"
                          Content="Pilares estruturais" IsChecked="True"
                          Checked="Configuracao_Changed" Unchecked="Configuracao_Changed"/>
                <Label Grid.Row="2" Grid.Column="1" Content="→" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPrefixoPilares" Grid.Row="2" Grid.Column="2"
                         Text="P" VerticalContentAlignment="Center" Margin="4,2"
                         TextChanged="TxtPrefixo_TextChanged"/>

                <CheckBox x:Name="chkContrav" Grid.Row="3" Grid.Column="0"
                          Content="Contraventamentos" IsChecked="True"
                          Checked="Configuracao_Changed" Unchecked="Configuracao_Changed"/>
                <Label Grid.Row="3" Grid.Column="1" Content="→" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPrefixoContrav" Grid.Row="3" Grid.Column="2"
                         Text="C" VerticalContentAlignment="Center" Margin="4,2"
                         TextChanged="TxtPrefixo_TextChanged"/>
            </Grid>
        </GroupBox>

        <!-- Numeracao -->
        <GroupBox Grid.Row="3" Header="Numeração">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Início:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtNumInicial" Grid.Column="1" Text="1" Margin="4,2"
                         VerticalContentAlignment="Center" TextChanged="TxtNum_TextChanged"/>

                <Label Grid.Column="3" Content="Dígitos:" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbDigitos" Grid.Column="4" Margin="4,2"
                          SelectedValuePath="Tag" SelectionChanged="CmbDigitos_Changed">
                    <ComboBoxItem Content="2 (ex: V-01)" Tag="2"/>
                    <ComboBoxItem Content="3 (ex: V-001)" Tag="3" IsSelected="True"/>
                    <ComboBoxItem Content="4 (ex: V-0001)" Tag="4"/>
                </ComboBox>

                <TextBlock Grid.Column="6" Grid.ColumnSpan="2" x:Name="txtExemplo"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="{DynamicResource AccentCardTextBrush}"
                           FontWeight="SemiBold"/>
            </Grid>
        </GroupBox>

        <!-- Destino da marca -->
        <GroupBox Grid.Row="4" Header="Destino da marca">
            <StackPanel>
                <RadioButton x:Name="rbParamMark" Content="Parâmetro Mark (recomendado)" IsChecked="True"
                             Checked="Configuracao_Changed"/>
                <RadioButton x:Name="rbParamComments" Content="Parâmetro Comments"
                             Margin="0,4,0,0" Checked="Configuracao_Changed"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <RadioButton x:Name="rbParamCustom" Content="Parâmetro customizado:"
                                 Checked="RbParamCustom_Changed" Unchecked="RbParamCustom_Changed"/>
                    <TextBox x:Name="txtParamCustom" Width="200" Margin="8,0,0,0"
                             VerticalContentAlignment="Center" IsEnabled="False"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Opcoes adicionais -->
        <GroupBox Grid.Row="5" Header="Opções">
            <StackPanel>
                <CheckBox x:Name="chkSobrescrever"
                          Content="Sobrescrever marcas existentes (se desmarcado, pula elementos já marcados)"
                          Checked="Configuracao_Changed" Unchecked="Configuracao_Changed"/>
                <CheckBox x:Name="chkDestaqueVisual"
                          Content="Aplicar destaque visual (cores por grupo) na vista ativa" IsChecked="True"
                          Margin="0,6,0,0"
                          Checked="Configuracao_Changed" Unchecked="Configuracao_Changed"/>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Label Content="Tolerância de comprimento (mm):" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtTolerancia" Text="1.0" Width="60" Margin="4,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Previa -->
        <Border Grid.Row="6" Style="{StaticResource SubtleCardBorder}" Margin="0,8,0,0">
            <TextBlock x:Name="txtResumo" TextWrapping="Wrap"/>
        </Border>

        <!-- Botoes -->
        <Border Grid.Row="7" Style="{StaticResource ActionBarBorder}" Margin="-16,12,-16,-16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancelar" Width="96"
                        Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0"/>
                <Button x:Name="btnOk" Content="Marcar Peças" Width="130"
                        Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
