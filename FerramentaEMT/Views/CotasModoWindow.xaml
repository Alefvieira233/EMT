<Window x:Class="FerramentaEMT.Views.CotasModoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modo da Cota"
        Width="560"
        MinWidth="480" MinHeight="360"
        MaxHeight="520"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Escolha Como Cotar" Style="{StaticResource DialogTitleText}"/>
            <TextBlock Text="Selecione se a cota deve usar as faces dos elementos ou os eixos das famílias." Style="{StaticResource DialogSubtitleText}"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="Modo da cota">
            <StackPanel>
                <Border Style="{StaticResource AccentCardBorder}" Margin="0 0 0 12">
                    <StackPanel>
                        <RadioButton x:Name="rbFaces"
                                     Content="Cotar pelas faces"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     IsChecked="True"
                                     Margin="0 0 0 6"/>
                        <TextBlock Text="Usa a geometria visível dos elementos. É a opção mais direta quando você quer cotar contornos reais."
                                   Style="{StaticResource SectionBodyText}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SubtleCardBorder}">
                    <StackPanel>
                        <RadioButton x:Name="rbEixos"
                                     Content="Cotar pelos eixos"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     Margin="0 0 0 6"/>
                        <TextBlock Text="Usa os alinhamentos centrais das famílias. É útil para modulação e conferência estrutural."
                                   Style="{StaticResource SectionBodyText}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </GroupBox>

        <Border Grid.Row="2" Style="{StaticResource ActionBarBorder}" Margin="-16,12,-16,-16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancelar" Width="96" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0"/>
                <Button x:Name="btnOk" Content="Continuar" Width="110" Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
