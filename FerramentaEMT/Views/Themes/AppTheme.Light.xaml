<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="RaisedSurfaceBrush" Color="#FAFBFC"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#D7DCE3"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#BCC5D1"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#17212B"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5F6B7A"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#D28B00"/>
    <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="#E7EBF0"/>
    <SolidColorBrush x:Key="DisabledBorderBrush" Color="#D3D8E0"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#96A0AE"/>
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFF5DF"/>
    <SolidColorBrush x:Key="WarningBorderBrush" Color="#E7CB87"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="#755400"/>
    <SolidColorBrush x:Key="AccentCardBackgroundBrush" Color="#EEF4FF"/>
    <SolidColorBrush x:Key="AccentCardBorderBrush" Color="#A4BDF6"/>
    <SolidColorBrush x:Key="AccentCardTextBrush" Color="#1E3A76"/>

    <!-- Aliases retroativos (mesma cor das chaves "novas") -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FAFBFC"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#17212B"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextBoxForegroundBrush" Color="#17212B"/>
</ResourceDictionary>
