<Window x:Class="FerramentaEMT.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sobre - FerramentaEMT"
        Width="540"
        MinWidth="460" MinHeight="380"
        MaxHeight="520"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0 0 0 16">
            <TextBlock Text="FerramentaEMT" Style="{StaticResource DialogTitleText}"/>
            <TextBlock x:Name="txtVersao" Text="Versão 1.0.0"
                       Style="{StaticResource DialogSubtitleText}"/>
        </StackPanel>

        <!-- Card de licenca -->
        <Border Grid.Row="1" x:Name="borderLicenca" Style="{StaticResource AccentCardBorder}" Margin="0 0 0 12">
            <StackPanel>
                <TextBlock x:Name="txtLicencaTitle"
                           Text="Estado da Licença"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Margin="0 0 0 6"/>
                <TextBlock x:Name="txtLicencaCorpo"
                           Text="—"
                           Style="{StaticResource SectionBodyText}"/>
            </StackPanel>
        </Border>

        <!-- Detalhes tecnicos -->
        <GroupBox Grid.Row="2" Header="Detalhes">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Email da licença:" Style="{StaticResource LabelText}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtEmail" Text="—"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Validade:" Style="{StaticResource LabelText}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtValidade" Text="—"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="ID desta máquina:" Style="{StaticResource LabelText}"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtMaquina" Text="—" FontFamily="Consolas"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Pasta de logs:" Style="{StaticResource LabelText}"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtPastaLog" Text="—" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>

        <!-- Botoes -->
        <Border Grid.Row="3" Style="{StaticResource ActionBarBorder}" Margin="-20,16,-20,-20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnAtivarOuRenovar"
                        Content="Ativar / Renovar"
                        Width="160"
                        Style="{StaticResource SecondaryActionButton}"
                        Margin="0,0,8,0"/>
                <Button x:Name="btnFechar"
                        Content="Fechar"
                        Width="100"
                        Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
