<Window x:Class="FerramentaEMT.Views.PipeRackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lançar Pipe Rack"
        Width="920"
        Height="640"
        MinWidth="820"
        MinHeight="560"
        MaxHeight="760"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FerramentaEMT;component/Views/Themes/AppTheme.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom" Style="{StaticResource ActionBarBorder}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancelar" Width="96" Height="32" Margin="0,0,8,0" Style="{StaticResource SecondaryActionButton}"/>
                <Button x:Name="btnCreate" Content="Criar" Width="96" Height="32" Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0 0 0 12">
                    <TextBlock Text="Configuração do Pipe Rack" Style="{StaticResource DialogTitleText}"/>
                    <TextBlock Text="Defina perfis, níveis e geometria para gerar pilares, vigas, montantes e diagonais do pipe rack." Style="{StaticResource DialogSubtitleText}"/>
                </StackPanel>

                <GroupBox Grid.Row="1" Header="Perfis estruturais">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Perfil do pilar:"/>
                        <ComboBox x:Name="cmbFamiliaPilar" Grid.Row="0" Grid.Column="1" SelectionChanged="CmbFamiliaPilar_SelectionChanged"/>
                        <ComboBox x:Name="cmbTipoPilar" Grid.Row="0" Grid.Column="3"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Perfil das vigas horizontais:"/>
                        <ComboBox x:Name="cmbFamiliaViga" Grid.Row="1" Grid.Column="1" SelectionChanged="CmbFamiliaViga_SelectionChanged"/>
                        <ComboBox x:Name="cmbTipoViga" Grid.Row="1" Grid.Column="3"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Perfil dos montantes:"/>
                        <ComboBox x:Name="cmbFamiliaMontante" Grid.Row="2" Grid.Column="1" SelectionChanged="CmbFamiliaMontante_SelectionChanged"/>
                        <ComboBox x:Name="cmbTipoMontante" Grid.Row="2" Grid.Column="3"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="Perfil das diagonais:"/>
                        <ComboBox x:Name="cmbFamiliaDiagonal" Grid.Row="3" Grid.Column="1" SelectionChanged="CmbFamiliaDiagonal_SelectionChanged"/>
                        <ComboBox x:Name="cmbTipoDiagonal" Grid.Row="3" Grid.Column="3"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Geometria principal">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Nível base dos pilares:"/>
                        <ComboBox x:Name="cmbNivelBase" Grid.Row="0" Grid.Column="1"/>

                        <Label Grid.Row="0" Grid.Column="2" Content="Nível topo dos pilares:" Margin="20,2,8,2"/>
                        <ComboBox x:Name="cmbNivelTopo" Grid.Row="0" Grid.Column="3"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Vãos entre pórticos (mm):"/>
                        <TextBox x:Name="txtVaos" Grid.Row="1" Grid.Column="1" Width="320" ToolTip="Ex.: 6000;6000;4500"/>

                        <Label Grid.Row="1" Grid.Column="2" Content="Altura do módulo (mm):" Margin="20,2,8,2"/>
                        <TextBox x:Name="txtAlturaModulo" Grid.Row="1" Grid.Column="3" Width="120"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource SectionBodyText}" Margin="4,10,0,0">
                            A altura total dos pilares é definida pela diferença entre o nível base e o nível topo. A altura do módulo define a altura de cada faixa treliçada.
                        </TextBlock>

                        <Label Grid.Row="2" Grid.Column="2" Content="Largura da estrutura (mm):" Margin="20,2,8,2"/>
                        <TextBox x:Name="txtLargura" Grid.Row="2" Grid.Column="3" Width="120"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="3" Header="Treliça e módulos">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Tipo de treliça:"/>
                        <ComboBox x:Name="cmbTipoTrelica" Grid.Row="0" Grid.Column="1" Width="180"/>

                        <Label Grid.Row="0" Grid.Column="2" Content="Módulos de largura:" Margin="20,2,8,2"/>
                        <ComboBox x:Name="cmbModulos" Grid.Row="0" Grid.Column="3" Width="110" HorizontalAlignment="Left"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Quantidade de módulos:"/>
                        <TextBox x:Name="txtQuantidadeModulos" Grid.Row="1" Grid.Column="1" Width="110"/>

                        <Label Grid.Row="1" Grid.Column="2" Content="Padrão das diagonais:" Margin="20,2,8,2"/>
                        <ComboBox x:Name="cmbPadraoDiagonais" Grid.Row="1" Grid.Column="3" Width="180" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Style="{StaticResource SectionBodyText}" Margin="4,10,0,0">
                            Tipos disponíveis: Pratt, Howe, Warren, X e diagonal simples. As diagonais podem alternar automaticamente ou manter um único sentido.
                        </TextBlock>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="4" Header="Execução">
                    <StackPanel>
                        <CheckBox x:Name="chkDesabilitarUniao" Content="Criar membros desconectados, sem união automática entre extremidades"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="5" Header="Sequência da ferramenta">
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource SectionBodyText}">
                        Depois de clicar em Criar, a ferramenta pedirá o ponto inicial do pipe rack e um segundo ponto
                        para definir a direção longitudinal. A ferramenta gera pilares nos apoios principais e, acima deles,
                        a caixa treliçada com vigas horizontais por módulo, montantes, diagonais e fechamento transversal.
                    </TextBlock>
                </GroupBox>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
